[TEMPLATE]
# =============================================================================
# PROVIDER API KEYS — set these to enable real data connections
# =============================================================================

# ── LLM Providers (at least one required) ────────────────────────────────
# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic (required for Claude Managed Agents deployment)
ANTHROPIC_API_KEY=sk-ant-...

# Google AI
GOOGLE_GENERATIVE_AI_API_KEY=...

# Mistral
MISTRAL_API_KEY=...

# OpenRouter (access 300+ models via a single API key)
OPENROUTER_API_KEY=...

# Default model (provider/model-name format)
# openrouter/free is a router but may not have free models with tool support
# Use a specific free model with tool support:
DEFAULT_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free

# Guardrail model for processors (prompt injection, PII, moderation)
GUARDRAIL_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free

# Storage database URL for memory (defaults to in-memory SQLite)
# For production, use a file path or Turso/libSQL URL:
# MASTRA_DB_URL=file:./mastra.db
# MASTRA_DB_URL=libsql://your-db.turso.io?authToken=your-token
MASTRA_DB_URL=:memory:

# =============================================================================
# MCP DATA CONNECTORS — 19 servers across official cookbook + general providers
# =============================================================================
# All servers are hosted/remote HTTP endpoints. Auth is via API key Bearer
# token unless noted otherwise. A subscription is required — contact the provider.

# ── Servers required by official managed-agent-cookbooks YAML configs ──────────
# These are referenced by name in the subagent tool/MCP declarations.

# CapIQ — equity research, trading multiples, comps, deal databases
# (used by pitch-agent, market-researcher, earnings-reviewer, model-builder, meeting-prep-agent)
CAPIQ_API_KEY=your_capiq_api_key
CAPIQ_MCP_URL=https://your-capiq-endpoint.com/mcp

# Daloopa — document extraction for filings, transcripts, financial statements
# (used by pitch-agent, earnings-reviewer, model-builder)
DALOOPA_API_KEY=your_daloopa_api_key

# FactSet — research, analytics, consensus estimates, pricing
# (used by market-researcher, earnings-reviewer)
FACTSET_API_KEY=your_factset_api_key

# Screening — KYC/AML sanctions and PEP screening
# (used by kyc-screener)
SCREENING_API_KEY=your_screening_api_key
SCREENING_MCP_URL=https://your-screening-endpoint.com/mcp

# Internal GL — month-end close, trial balance, ledger data
# (used by gl-reconciler, month-end-closer)
INTERNAL_GL_API_KEY=your_internal_gl_api_key
INTERNAL_GL_MCP_URL=https://your-internal-gl-endpoint.com/mcp

# Subledger — break detection, variance analysis, reconciliation
# (used by gl-reconciler)
SUBLEDGER_API_KEY=your_subledger_api_key
SUBLEDGER_MCP_URL=https://your-subledger-endpoint.com/mcp

# NAV — fund administration, LP statement reconciliation, NAV packs
# (used by statement-auditor)
NAV_API_KEY=your_nav_api_key
NAV_MCP_URL=https://your-nav-endpoint.com/mcp

# Portfolio — valuation, marks, waterfall, fund performance
# (used by valuation-reviewer)
PORTFOLIO_API_KEY=your_portfolio_api_key
PORTFOLIO_MCP_URL=https://your-portfolio-endpoint.com/mcp

# CRM — client relationship data, meeting preparation, holdings
# (used by meeting-prep-agent)
CRM_API_KEY=your_crm_api_key
CRM_MCP_URL=https://your-crm-endpoint.com/mcp

# ── General-purpose financial data providers ───────────────────────────

# Morningstar — equity research, fundamentals, estimates
MORNINGSTAR_API_KEY=your_morningstar_api_key

# S&P Global / Capital IQ — Kensho-powered financial data
# Note: the partner plugin also uses this key (spglobal alias)
SP_GLOBAL_API_KEY=your_sp_global_api_key

# Moody's — credit data, credit analytics, risk assessment
MOODYS_API_KEY=your_moodys_api_key

# MT Newswires — real-time financial news, earnings releases
MTNEWSWIRE_API_KEY=your_mtnewswire_api_key

# Aiera — earnings call transcription, analyst estimates
AIERA_API_KEY=your_aiera_api_key

# LSEG (London Stock Exchange Group) — Refinitiv, Lipper, IBES, bond pricing
# Uses custom Bearer header prefix
LSEG_API_KEY=your_lseg_api_key

# PitchBook — private market data: VC, PE, M&A deals
PITCHBOOK_API_KEY=your_pitchbook_api_key

# Chronograph — alternative data, supply chain, consumer insights
CHRONOGRAPH_API_KEY=your_chronograph_api_key

# Egnyte — document management for deal rooms and data rooms
EGNYTE_API_KEY=your_egnyte_api_key

# Box — cloud content management, deal rooms, document storage
BOX_API_KEY=your_box_api_key
