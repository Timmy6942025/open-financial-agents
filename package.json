{
  "name": "open-financial-agents",
  "version": "0.1.0",
  "description": "Open-source, model-agnostic financial services agent platform — ported from Anthropic's financial-services reference library. Uses Mastra for AI agent orchestration with support for any LLM provider.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "mastra dev",
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "validate": "tsx scripts/validate.ts",
    "sync-skills": "tsx scripts/sync-skills.ts",
    "deploy-agent": "tsx scripts/deploy-agent.ts",
    "cli": "tsx cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.67",
    "@mastra/ai-sdk": "^1.4.4",
    "@mastra/core": "^1.38.0",
    "@mastra/libsql": "^1.12.0",
    "@mastra/mcp": "^1.9.0",
    "@mastra/memory": "^1.20.1",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "ai": "^6.0.195",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "mastra": "^1.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
